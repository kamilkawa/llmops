# Copy to .env in the project root (or homework/.env for Docker) and fill in your keys.
# Do not commit .env to git.

# LLM — OpenRouter (cloud variant; no local vLLM needed on macOS)
OPENROUTER_API_KEY=your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-3.5-flash

# OpenWeatherMap — https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweather-key

# Tavily — https://tavily.com (optional; keyless mode also works for basic search)
TAVILY_API_KEY=your-tavily-key

# MCP URLs (defaults work for local dev; Docker Compose overrides these)
OPENWEATHER_MCP_URL=http://localhost:8010/mcp
